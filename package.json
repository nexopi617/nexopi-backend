const express = require('express');
const axios = require('axios');
const cors = require('cors');
const path = require('path');

const app = express();
const PORT = process.env.PORT || 3000;

// مهم: حط الـ Pi Server API Key متاعك هنا
// تاخذو من Pi Developer Portal -> App -> API Key
const PI_API_KEY = process.env.PI_API_KEY || 'YOUR_PI_SERVER_API_KEY_HERE';
const PI_API_URL = 'https://api.minepi.com/v2';

app.use(cors());
app.use(express.json());
app.use(express.static(path.join(__dirname, 'public'))); // لو عندك مجلد public

// Serve الـ index.html
app.get('/', (req, res) => {
    res.sendFile(path.join(__dirname, 'index.html'));
});

// Serve الـ manifest.json
app.get('/manifest.json', (req, res) => {
    res.sendFile(path.join(__dirname, 'manifest.json'));
});

// 1. Approve Payment - السيرفر يوافق على الدفع
app.post('/approve-payment', async (req, res) => {
    const { paymentId } = req.body;
    
    if (!paymentId) {
        return res.status(400).json({ error: 'paymentId مطلوب' });
    }

    try {
        console.log('Approving payment:', paymentId);
        
        const response = await axios.post(
            `${PI_API_URL}/payments/${paymentId}/approve`,
            {},
            {
                headers: {
                    'Authorization': `Key ${PI_API_KEY}`,
                    'Content-Type': 'application/json'
                }
            }
        );

        console.log('Payment approved:', response.data);
        res.status(200).json({ message: 'Approved', data: response.data });
        
    } catch (error) {
        console.error('Approve error:', error.response?.data || error.message);
        res.status(500).json({ 
            error: 'فشل الموافقة على الدفع',
            details: error.response?.data || error.message 
        });
    }
});

// 2. Complete Payment - السيرفر يكمل الدفع بعد ما يتأكد من البلوكتشين
app.post('/complete-payment', async (req, res) => {
    const { paymentId, txid } = req.body;
    
    if (!paymentId || !txid) {
        return res.status(400).json({ error: 'paymentId و txid مطلوبين' });
    }

    try {
        console.log('Completing payment:', paymentId, 'txid:', txid);
        
        const response = await axios.post(
            `${PI_API_URL}/payments/${paymentId}/complete`,
            { txid: txid },
            {
                headers: {
                    'Authorization': `Key ${PI_API_KEY}`,
                    'Content-Type': 'application/json'
                }
            }
        );

        console.log('Payment completed:', response.data);
        res.status(200).json({ message: 'Completed', data: response.data });
        
    } catch (error) {
        console.error('Complete error:', error.response?.data || error.message);
        res.status(500).json({ 
            error: 'فشل إكمال الدفع',
            details: error.response?.data || error.message 
        });
    }
});

// Pi Domain Validation - لازم للـ Mainnet
app.get('/.well-known/pi-domain-approval.json', (req, res) => {
    // حط الـ validation key متاعك من Pi Developer Portal
    res.json({
        "pi_domain_approval": "YOUR_VALIDATION_KEY_HERE"
    });
});

app.listen(PORT, () => {
    console.log(`NexoPi server running on port ${PORT}`);
    if (PI_API_KEY === 'YOUR_PI_SERVER_API_KEY_HERE') {
        console.warn('⚠️  WARNING: حط الـ PI_API_KEY متاعك في Environment Variables');
    }
});
